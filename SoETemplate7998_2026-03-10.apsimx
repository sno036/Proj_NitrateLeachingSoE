                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "// Determines when and how much irrigation is to be applied based on given instructions and/or soil condition.",
                    "// Developed by RCichota, last updated in 10/Dec/2021",
                    "",
                    "using System;",
                    "using System.Xml.Serialization;",
                    "using APSIM.Shared.Utilities;",
                    "using Models.Interfaces;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    [System.Xml.Serialization.XmlInclude(typeof(Model))]",
                    "    public class Script : Model",
                    "    {",
                    "        //> Links to other Apsim models",
                    "        [Link] private Clock clock;",
                    "        [Link] private IWeather weather;",
                    "        [Link] private Irrigation irrigator;",
                    "        [Link] private IPhysical soilPhysical;",
                    "        [Link] private ISoilWater soilWater;",
                    "        [Link(IsOptional = true)] private IPlant existingCrop;",
                    "        [Link] private ISummary summary;",
                    "",
                    "        //> User inputs from properties tab",
                    "        [Separator(\"Generic irrigation management\")]",
                    "        [Description(\" Turn automatic irrigation on?\")]",
                    "        public yesNoAnswer AllowIrrigation { get; set; }",
                    "        [Description(\" Start of irrigation season (dd-MMM)\")]",
                    "        public string SeasonStartDate { get; set; }",
                    "        [Description(\" End of irrigation season (dd-MMM)\")]",
                    "        public string SeasonEndDate { get; set; }",
                    "",
                    "        [Separator(\"Parameters defining how the irrigation is triggered\")]",
                    "        [Description(\" How irrigation should be triggered? \")]",
                    "        public IrrigationTriggerTypes IrrigationTriggerType { get; set; }",
                    "        [Description(\"  Number of days between irrigations, if using fixed interval\")]",
                    "        public int IntervalBetweenIrrigations { get; set; }",
                    "        [Description(\"  Deficit to trigger irrigation, if using soil deficit (% PAWC)\")]",
                    "        public double TriggerDeficit { get; set; }",
                    "",
                    "        [Separator(\"Parameters defining how much irrigation is applied\")]",
                    "        [Description(\" How irrigation amount is determined? \")]",
                    "        public IrrigationAmountTypes IrrigationAmountType { get; set; }",
                    "        [Description(\"  Amount of irrigation to apply, if setting amount (mm)\")]",
                    "        public double GivenAmount { get; set; }",
                    "        [Description(\"  Deficit to stop irrigation, if based on soil deficit (% PAWC)\")]",
                    "        public double TargetDeficit { get; set; }",
                    "        [Description(\"  Maximum irrigation application (mm/day)\")]",
                    "        public double MaximumAmount { get; set; }",
                    "",
                    "        [Separator(\"Parameters defining extra constraint to irrigation\")]",
                    "        [Description(\" Only apply irrigation if there's a crop?\")]",
                    "        public yesNoAnswer CheckCropActive { get; set; }",
                    "        [Description(\" Skip rainy days (rain > 5mm)?\")]",
                    "        public yesNoAnswer SkipRainDays { get; set; }",
                    "        [Description(\" Minimum number of days between irrigations (ignored if irrigating using fixed interval\")]",
                    "        public double ReturnDays { get; set; }",
                    "",
                    "        [Separator(\"Parameters for computing soil water deficit\")]",
                    "        [Description(\"Depth to calculate PAWC (mm)\")]",
                    "        public double DepthForPAWC { get; set; }",
                    "",
                    "        //> Outputs from this manager",
                    "        [XmlIgnore] public double IrrigLayerSWDeficit { get; set; }",
                    "        [XmlIgnore] public double TopSWC { get; set; }",
                    "        [XmlIgnore] public double TopDUL { get; set; }",
                    "        [XmlIgnore] public double TopLL { get; set; }",
                    "        [XmlIgnore] public double DaysSinceIrrigation { get; set; }",
                    "        [XmlIgnore] public double AmountToApply { get; set; }",
                    "        [XmlIgnore] public double SeasonAppliedAmount { get; set; }",
                    "",
                    "        //> Internal variables",
                    "        private int bottomLayer;",
                    "        private double fracBottomLayer;",
                    "        private bool irrigationIsAllowed;",
                    "        private bool checkingCropActive;",
                    "        private bool skippingRainDays;",
                    "        private bool seasonIsOpen;",
                    "        private bool cropIsActive;",
                    "        private bool rainIsNotSignificant;",
                    "        private bool irrigatorIsAvailable;",
                    "        private bool soilMoistureIsLow;",
                    "",
                    "",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void OnStartOfSimulation(object sender, EventArgs e)",
                    "        {",
                    "            //Can we irrigate at all?",
                    "            irrigationIsAllowed = false;",
                    "            if (AllowIrrigation == yesNoAnswer.Yes)",
                    "            {",
                    "                irrigationIsAllowed = true;",
                    "",
                    "                //Do we need to check crop?",
                    "                checkingCropActive = false;",
                    "                if (CheckCropActive == yesNoAnswer.Yes)",
                    "                {",
                    "                    checkingCropActive = true;",
                    "                    if(existingCrop == null)",
                    "                    {",
                    "                        throw new Exception(\" Manager requires checking active crop, but no crop is present\");",
                    "                    }",
                    "                }",
                    "",
                    "                //Do we need to check rainfall?",
                    "                skippingRainDays = false;",
                    "                if (SkipRainDays == yesNoAnswer.Yes)",
                    "                {",
                    "                    skippingRainDays = true;",
                    "                }",
                    "            }",
                    "",
                    "            //Calculate soil water variables",
                    "            double depthFromSurface = 0.0;",
                    "            for (int layer = 0; layer < soilPhysical.Thickness.Length; layer++)",
                    "            {",
                    "                fracBottomLayer = Math.Min(1.0, (DepthForPAWC - depthFromSurface) / soilPhysical.Thickness[layer]);",
                    "                TopLL += soilPhysical.LL15mm[layer] * fracBottomLayer;",
                    "                TopDUL += soilPhysical.DULmm[layer] * fracBottomLayer;",
                    "                depthFromSurface += soilPhysical.Thickness[layer];",
                    "                if (depthFromSurface >= DepthForPAWC)",
                    "                {",
                    "                    bottomLayer = layer;",
                    "                    layer = soilPhysical.Thickness.Length;",
                    "                }",
                    "            }",
                    "",
                    "            // write message in summary",
                    "            summary.WriteMessage(this,\" Automatic irrigation manager initialised\", MessageType.Diagnostic);",
                    "            if (irrigationIsAllowed)",
                    "            {",
                    "                summary.WriteMessage(this,\"  Irrigation is enabled between \" + SeasonStartDate + \" and \" + SeasonEndDate, MessageType.Diagnostic);",
                    "                if (IrrigationTriggerType == IrrigationTriggerTypes.FixedInterval)",
                    "                {",
                    "                    summary.WriteMessage(this,\"  Irrigation will be triggered every \" + IntervalBetweenIrrigations + \" days\", MessageType.Diagnostic);",
                    "                }",
                    "                else",
                    "                {",
                    "                    summary.WriteMessage(this,\"  Irrigation will be triggered every time soil moisture is below \" + TriggerDeficit.ToString(\"#0.0\") + \"% of PAWC\", MessageType.Diagnostic);",
                    "                }",
                    "",
                    "                if (IrrigationAmountType == IrrigationAmountTypes.GivenAmount)",
                    "                {",
                    "                    summary.WriteMessage(this,\"  Amount to be applied is fixed at \" + Math.Min(MaximumAmount, GivenAmount).ToString(\"#0.0\") + \"mm each application\", MessageType.Diagnostic);",
                    "                }",
                    "                else",
                    "                {",
                    "                    summary.WriteMessage(this,\"  Amount to be applied will aim to bring soil moisture up to \" + TargetDeficit.ToString(\"#0.0\") + \"% of PAWC\", MessageType.Diagnostic);",
                    "                    summary.WriteMessage(this,\"   limited to \" + MaximumAmount.ToString(\"#0.0\") + \"mm in each application\", MessageType.Diagnostic);",
                    "                }",
                    "            }",
                    "            else",
                    "            {",
                    "                summary.WriteMessage(this,\"  Irrigation is disabled\", MessageType.Diagnostic);",
                    "            }",
                    "        }",
                    "",
                    "        [EventSubscribe(\"StartOfDay\")]",
                    "        private void OnStartOfDay(object sender, EventArgs e)",
                    "        {",
                    "            //Check for whether we are within the irrigation season",
                    "            if(DateUtilities.WithinDates(SeasonStartDate, clock.Today, SeasonEndDate))",
                    "            {",
                    "                seasonIsOpen = true;",
                    "            }",
                    "            else",
                    "            {",
                    "                seasonIsOpen = false;",
                    "                SeasonAppliedAmount = 0;",
                    "            }",
                    "",
                    "            //Check for whether there is a crop that needs irrigation",
                    "            cropIsActive = true;",
                    "            if (checkingCropActive)",
                    "            {",
                    "                if (!existingCrop.IsAlive)",
                    "                {",
                    "                    cropIsActive = false;",
                    "                }",
                    "            }",
                    "            //if ((existingCrop.Phenology.Stage >= 3.0) && (existingCrop.Phenology.Stage < 6.0))",
                    "",
                    "            //Check whether there is significant rainfall",
                    "            rainIsNotSignificant = true;",
                    "            if (skippingRainDays && weather.Rain > 5.0)",
                    "            {",
                    "                rainIsNotSignificant = false;",
                    "            }",
                    "",
                    "            //Check whether the irrigator available",
                    "            irrigatorIsAvailable = false;",
                    "            DaysSinceIrrigation += 1;",
                    "            if(IrrigationTriggerType == IrrigationTriggerTypes.FixedInterval)",
                    "            {",
                    "                if (DaysSinceIrrigation >= IntervalBetweenIrrigations)",
                    "                {",
                    "                    irrigatorIsAvailable = true;",
                    "                }",
                    "            }",
                    "            else",
                    "            {",
                    "                if (DaysSinceIrrigation >= ReturnDays)",
                    "                {",
                    "                    irrigatorIsAvailable = true;",
                    "                }",
                    "            }",
                    "        }",
                    "",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            //Get current soil moisture at appropriate depth",
                    "            TopSWC = 0.0;",
                    "            for (int layer = 0; layer < bottomLayer; layer++)",
                    "            {",
                    "                TopSWC += soilWater.SWmm[layer];",
                    "            }",
                    "            TopSWC += soilWater.SWmm[bottomLayer] * fracBottomLayer;",
                    "",
                    "            //Check whether the soil is dry enough to require irrigation",
                    "            IrrigLayerSWDeficit = TopSWC - TopDUL;",
                    "            if(IrrigationTriggerType == IrrigationTriggerTypes.TriggerBySoilDeficit)",
                    "            {",
                    "                soilMoistureIsLow = false;",
                    "                if (Math.Max(0.0, -IrrigLayerSWDeficit) >= (TopDUL - TopLL) * (100.0 - TriggerDeficit) / 100.0)",
                    "                {",
                    "                    soilMoistureIsLow = true;",
                    "                }",
                    "            }",
                    "            else",
                    "            { // moisture is not checked",
                    "                soilMoistureIsLow = true;",
                    "            }",
                    "",
                    "            //Are all the conditions ratifying irrigation",
                    "            if (irrigationIsAllowed && seasonIsOpen && cropIsActive && irrigatorIsAvailable && rainIsNotSignificant && soilMoistureIsLow)",
                    "            {",
                    "                //Lets bloody well irrigate then!!!!",
                    "                if(IrrigationAmountType == IrrigationAmountTypes.GivenAmount)",
                    "                {",
                    "                    AmountToApply = Math.Min(GivenAmount, MaximumAmount);",
                    "                }",
                    "                else",
                    "                {",
                    "                    AmountToApply = TopLL + (TopDUL - TopLL) * TargetDeficit / 100.0 - TopSWC;",
                    "                    AmountToApply = Math.Max(0.0, Math.Min(AmountToApply, MaximumAmount));",
                    "                }",
                    "",
                    "                irrigator.Apply(amount: AmountToApply, depth: 0.0, duration: 1440, willRunoff: true);",
                    "                DaysSinceIrrigation = 0;",
                    "                SeasonAppliedAmount += AmountToApply;",
                    "            }",
                    "        }",
                    "",
                    "",
                    "        /// <summary>Flag for a yes or no answer</summary>",
                    "        public enum yesNoAnswer",
                    "        {",
                    "            /// <summary>Positive answer</summary>",
                    "            Yes,",
                    "            /// <summary>Negative answer</summary>",
                    "            No",
                    "        }",
                    "",
                    "        /// <summary>Flag how irrigation will be triggered</summary>",
                    "        public enum IrrigationTriggerTypes",
                    "        {",
                    "            /// <summary>Setting a fixed interval</summary>",
                    "            FixedInterval,",
                    "            /// <summary>Setting a soil deficit</summary>",
                    "            TriggerBySoilDeficit",
                    "        }",
                    "",
                    "        /// <summary>Flag how much irrigation will be applied</summary>",
                    "        public enum IrrigationAmountTypes",
                    "        {",
                    "            /// <summary>Setting a fixed interval</summary>",
                    "            GivenAmount,",
                    "            /// <summary>Setting a soil deficit</summary>",
                    "            BasedOnSoilDeficit",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "AllowIrrigation",
                      "Value": "Yes"
                    },
                    {
                      "Key": "SeasonStartDate",
                      "Value": "1-Sep"
                    },
                    {
                      "Key": "SeasonEndDate",
                      "Value": "30-Apr"
                    },
                    {
                      "Key": "IrrigationTriggerType",
                      "Value": "TriggerBySoilDeficit"
                    },
                    {
                      "Key": "IntervalBetweenIrrigations",
                      "Value": "0"
                    },
                    {
                      "Key": "TriggerDeficit",
                      "Value": "60"
                    },
                    {
                      "Key": "IrrigationAmountType",
                      "Value": "BasedOnSoilDeficit"
                    },
                    {
                      "Key": "GivenAmount",
                      "Value": "0"
                    },
                    {
                      "Key": "TargetDeficit",
                      "Value": "90"
                    },
                    {
                      "Key": "MaximumAmount",
                      "Value": "50"
                    },
                    {
                      "Key": "CheckCropActive",
                      "Value": "Yes"
                    },
                    {
                      "Key": "SkipRainDays",
                      "Value": "Yes"
                    },
                    {
                      "Key": "ReturnDays",
                      "Value": "3"
                    },
                    {
                      "Key": "DepthForPAWC",
                      "Value": "500"
                    }
                  ],
                  "Name": "AutomaticIrrigation",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Models.Interfaces;",
                    "using APSIM.Shared.Utilities;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using Models.Core;",
                    "using System;",
                    "using System.Linq;",
                    "using Models.Soils.Nutrients;",
                    "using Newtonsoft.Json;",
                    "using System.Xml.Serialization;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] private Clock clock;",
                    "        [Link] private Fertiliser fertiliser;",
                    "        [Link] private ISummary summary;",
                    "        [Link] private Nutrient nutrient;",
                    "        [Link] private DateChangerScript dateChangerScript;",
                    "",
                    "        [Separator(\"Nitrogen will be applied on the date set by the DateChanger Script\")]",
                    "        ",
                    "        [Description(\"Amount of N to apply (kg N /ha) for each deposition\")]",
                    "        public double Amount { get; set; }",
                    "",
                    "        [Description(\"Type of fertiliser to apply? \")] ",
                    "        [Display(Type = DisplayType.FertiliserType)]public string FertiliserType { get; set; }",
                    "",
                    "        [XmlIgnore] public double Depth { get; set; }",
                    "\t\t[XmlIgnore] public DateTime myApplicationDate {get; set;}",
                    "        [XmlIgnore] public double SpikeNApplied { get; set; }",
                    "        ",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void FindSoilNOrNutrient(object sender, EventArgs e)",
                    "        {",
                    "            myApplicationDate = dateChangerScript.ApplicationDate;",
                    "            summary.WriteMessage(this, \"The application date will be \" + myApplicationDate, MessageType.Information);",
                    "        }",
                    "",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            SpikeNApplied = 0.0;",
                    "            if (clock.Today == myApplicationDate)",
                    "            {",
                    "                fertiliser.Apply(Amount, FertiliserType, 5.0);",
                    "                summary.WriteMessage(this, \"N addition of \" + Amount + \" kg N /ha to a depth of \" + Depth + \" mm\", MessageType.Information); ",
                    "                SpikeNApplied = Amount;",
                    "            }",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "Amount",
                      "Value": "450"
                    },
                    {
                      "Key": "FertiliserType",
                      "Value": "NO3N"
                    }
                  ],
                  "Name": "ApplySpikeOfN",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "// Gets an output at a particular depth for reporting",
                    "using System;",
                    "using System.Xml.Serialization;",
                    "using APSIM.Shared.Utilities;",
                    "using Models.Interfaces;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using Models.Soils.Nutrients;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    [System.Xml.Serialization.XmlInclude(typeof(Model))]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] private Clock clock;",
                    "        [Link] private IPhysical physical;",
                    "        [Link] private ISoilWater soilWater;",
                    "        [Link] private Nutrient nutrient;",
                    "        [Link(ByName = true)] private ISolute urea;",
                    "        [Link(ByName = true)] private ISolute nH4;",
                    "        [Link(ByName = true)] private ISolute nO3;",
                    "        [Link] private ISummary summary;",
                    "",
                    "        [Separator(\"This just gets leaching at the specified depth for reporting\")]",
                    "",
                    "        [Description(\"Depth for reporting (mm)\")]",
                    "        public double TargetDepth { get; set; }",
                    "",
                    "        [XmlIgnore] public double LeachingForOutput { get; set; }",
                    "        [XmlIgnore] public double DrainageForOutput { get; set; }",
                    "        [XmlIgnore] public double DenitrificationForOutput { get; set; }",
                    "        [XmlIgnore] public double N2OForOutput { get; set; }",
                    "        [XmlIgnore] public int Layer { get; set; }",
                    "",
                    "",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void OnStartOfSimulation(object sender, EventArgs e)",
                    "        {",
                    "            Layer = 0;",
                    "            for (int i = 0; i < physical.Thickness.Length; i++)",
                    "            {",
                    "                if (Layer < 1 && physical.ThicknessCumulative[i] >= TargetDepth)  // this will only trigger the first time the cumulative depth is greater than the target depth",
                    "                    Layer = i;   ",
                    "            }",
                    "        }",
                    "",
                    "        [EventSubscribe(\"DoReportCalculations\")]",
                    "        private void OnDoReportCalculations(object sender, EventArgs e)",
                    "        {",
                    "            LeachingForOutput = urea.Flow[Layer] + nH4.Flow[Layer] + nO3.Flow[Layer];",
                    "            DrainageForOutput = soilWater.Flow[Layer] + soilWater.Flux[Layer];",
                    "            ",
                    "            DenitrificationForOutput = 0.0;",
                    "            N2OForOutput = 0.0;",
                    "            for (int i = 0; i <= Layer; i++)",
                    "            {",
                    "                DenitrificationForOutput += nutrient.DenitrifiedN[i];",
                    "                if (physical.ThicknessCumulative[i] <= 300.0)",
                    "                    N2OForOutput += nutrient.N2Oatm[i];",
                    "            }",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "TargetDepth",
                      "Value": "1000"
                    }
                  ],
                  "Name": "Outputs1000mm",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
