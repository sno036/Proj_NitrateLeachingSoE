        {
          "$type": "Models.Core.Simulation, Models",
          "Descriptors": null,
          "Name": "Base",
          "ResourceName": null,
          "Children": [
            {
              "$type": "Models.Manager, Models",
              "CodeArray": [
                "using System;",
                "using System.Xml.Serialization;",
                "using APSIM.Shared.Utilities;",
                "using Models.Interfaces;",
                "using Models.Core;",
                "using Models.PMF;",
                "using Models.Soils;",
                "using Models.WaterModel;",
                "",
                "namespace Models",
                "{",
                "\t[Serializable]",
                "\tpublic class DateChangerScript : Model",
                "\t{",
                "\t\t//> Links to other Apsim models",
                "\t\t[Link] private Clock clock;",
                "        [Link] private ISummary summary;",
                "\t",
                "\t\t[Separator(\"Change the start and end date from the factor levels\")]",
                "",
                "",
                "\t\t[Description(\"Year of interest\")]",
                "\t\tpublic int Year {get; set;}",
                "",
                "\t\t[Description(\"Month of interest\")]",
                "\t\tpublic int Month {get; set;}",
                "",
                "\t\t[Description(\"Day of interest\")]",
                "\t\tpublic int Day {get; set;}",
                "",
                "\t\t[XmlIgnore] public string DateAsString {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDate {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus30 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus60 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus90 {get; set;}",
                "\t\t",
                "\t\t[EventSubscribe(\"Commencing\")]",
                "\t\tprivate void OnComencing(object sender, EventArgs e)",
                "\t\t{",
                "",
                "            DateAsString = Day + \"-\" + Month + \"-\" + Year;",
                "            ApplicationDate = new DateTime(Year, Month, Day);",
                "            ",
                "            clock.StartDate = ApplicationDate.AddMonths(-5);",
                "            clock.EndDate = ApplicationDate.AddYears(2).AddDays(-1);",
                "            ",
                "            ApplicationDatePlus30 = ApplicationDate.AddDays(30);",
                "            ApplicationDatePlus60 = ApplicationDate.AddDays(60);",
                "            ApplicationDatePlus90 = ApplicationDate.AddDays(90);",
                "",
                "            ",
                "\t\t}",
                "\t\t",
                "\t\t[EventSubscribe(\"StartOfSimulation\")]",
                "\t\tprivate void OnStartOfSimulation(object sender, EventArgs e)",
                "\t\t{",
                "            summary.WriteMessage(this, \"In DateChanger, the application date will be \" + ApplicationDate, MessageType.Information);",
                "            ",
                "\t\t}",
                "\t\t",
                "\t\t[EventSubscribe(\"StartOfDay\")]",
                "\t\tprivate void OnStartOfDay(object sender, EventArgs e)",
                "\t\t{",
                "\t\t}",
                "\t\t",
                "\t\t[EventSubscribe(\"DoManagement\")]",
                "\t\tprivate void OnDoManagement(object sender, EventArgs e)",
                "\t\t{",
                "\t\t}",
                "\t\t",
                "\t}",
                "}"
              ],
              "Parameters": [
                {
                  "Key": "Year",
                  "Value": "1900"
                },
                {
                  "Key": "Month",
                  "Value": "1"
                },
                {
                  "Key": "Day",
                  "Value": "15"
                }
              ],
              "Name": "DateChanger",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
