            },
            {
              "$type": "Models.Summary, Models",
              "Verbosity": 100,
              "Name": "SummaryFile",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            },
            {
              "$type": "Models.Core.Zone, Models",
              "Area": 1.0,
              "Slope": 0.0,
              "AspectAngle": 0.0,
              "Altitude": 0.0,
              "CanopyType": null,
              "Name": "Block",
              "ResourceName": null,
              "Children": [
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Models.Soils;",
                    "using System;",
                    "using System.Linq;",
                    "using System.Diagnostics;",
                    "using System.IO;",
                    "using Models.Core;",
                    "using Models.Interfaces;",
                    "using Models.Climate;",
                    "using APSIM.Shared.Utilities;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] Clock clock;",
                    "        [Link] Weather weather;",
                    "        [Link] Irrigation irrigation;",
                    "        [Link] ISummary summary;",
                    "        [Link] Physical physical;",
                    "        [Link] Water water;",
                    "",
                    "",
                    "        [Separator(\"Permit or disallow irrigaiton\")]",
                    "",
                    "        [Description(\" Turn automatic irrigation on?\")]",
                    "        public bool AllowIrrigation { get; set; }",
                    "",
                    "        [Description(\"      ... but not when annual average rainfall exceeds a value of (mm)\")]",
                    "        public double CriticalAnnualAverageRainfall { get; set; }",
                    "",
                    "        [Separator(\"All soils\")]",
                    "",
                    "        [Description(\"Start of irrigation season (dd-mmm)\")] ",
                    "        public string IrrigStart { get; set; }",
                    "",
                    "        [Description(\"End of irrigation season (dd-mmm)\")] ",
                    "        public string IrrigEnd { get; set; }",
                    "",
                    "        [Description(\"Enter the depth to which water deficit is computed (mm)\")] ",
                    "        public double SoilDepth { get; set; }",
                    "        ",
                    "        [Description(\"PAW below which soil is considered 'shallow' (mm)\")] ",
                    "        public double CritPAWForShallow { get; set; }",
                    "",
                    "        [Description(\"Amount of rainfall over the last 3 days to cause pause to irrigator (mm)\")] ",
                    "        public double CritRainToPause { get; set; }",
                    "",
                    "        [Description(\"Number of days to pause irrigator after critical delay (days)\")] ",
                    "        public double DaysToPauseOnCritRain { get; set; }",
                    "        ",
                    "        [Separator(\"Shallow soils\")]",
                    "        ",
                    "        [Description(\"Irrigation return period for shallow soils (days)\")] ",
                    "        public double IrrigReturnShallow { get; set; }",
                    "",
                    "        [Description(\"Effective irrigation amount for shallow soils (mm)\")] ",
                    "        public double IrrigAmtShallow { get; set; }",
                    "",
                    "        [Description(\"Percentage of PAW at which to irrigate shallow soils (%)\")] ",
                    "        public double PercPAWIrrigDeficitShallow { get; set; }",
                    "",
                    "        [Description(\"Irrigation efficiency for shallow soils (%)\")] ",
                    "        public double IrrigEffShallow { get; set; }",
                    "",
                    "        [Separator(\"Deep soils\")]",
                    "        ",
                    "        [Description(\"Irrigation return period for deep soils (days)\")] ",
                    "        public double IrrigReturnDeep { get; set; }",
                    "",
                    "        [Description(\"Effective irrigation amount for deep soils (mm)\")] ",
                    "        public double IrrigAmtDeep { get; set; }",
                    "",
                    "        [Description(\"Soil water deficit at which to irrigate deep soils (mm)\")] ",
                    "        public double IrrigDeficitDeep { get; set; }",
                    "",
                    "        [Description(\"Irrigation efficiency for deep soils (%)\")] ",
                    "        public double IrrigEffDeep { get; set; }",
                    "",
                    "",
                    "        // Output variables",
                    "        [Units(\"mm\")]",
                    "        public double TodayDeficit {get; set; }",
                    "         ",
                    "        [Units(\"mm\")]",
                    "        public double TodayDeficit_nve {get; set; }",
                    "         ",
                    "        [Units(\"\")]",
                    "        public double IrrigDay {get; set; }",
                    "         ",
                    "        [Units(\"\")]",
                    "        public double SoilPAW {get; set; }",
                    "         ",
                    "        [Units(\"\")]",
                    "        public double IrrigDeficit {get; set; }",
                    "        ",
                    "        [Units(\"\")]",
                    "        public double IrrigReturn {get; set; }",
                    "        ",
                    "        [Units(\"\")]",
                    "        public double IrrigAmt {get; set; }",
                    "        ",
                    "        [Units(\"\")]",
                    "        public double IrrigEff {get; set; }",
                    "        ",
                    "        [Units(\"mm\")]",
                    "        public double Rain3 {get; set; }",
                    "        ",
                    "        [Units(\"mm\")]",
                    "        public double[] Rain_3 {get; set; } = new double[3];",
                    "        ",
                    "        [Units(\"\")]",
                    "        public double Days2Pause {get; set; }",
                    "",
                    "         // private variables",
                    "        private double irrigDeficitShallow {get; set; }",
                    "",
                    "         // private variables",
                    "        private double AnnualAverageRainfall {get; set; }",
                    "",
                    "        ",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void OnStartOfSimulation(object sender, EventArgs e)",
                    "        {",
                    "            AnnualAverageRainfall = GetAverageAnnualRainfallFromFile(weather.FullFileName);",
                    "            ",
                    "            if ((AllowIrrigation) && (AnnualAverageRainfall <= CriticalAnnualAverageRainfall))",
                    "            {",
                    "            ",
                    "                IrrigDay = 5000;  // so will reset to 1 on first day",
                    "    ",
                    "                Rain3 = 0.0;",
                    "                Rain_3[0] = 0.0; Rain_3[1] = 0.0; Rain_3[2] = 0.0;",
                    "    ",
                    "                SoilPAW = 0.0;",
                    "                double mySoilDepth = 0;",
                    "                for (int z = 0; z <= physical.Thickness.Length - 1; z++)",
                    "                {",
                    "                    mySoilDepth = mySoilDepth + physical.Thickness[z];",
                    "                    if (mySoilDepth <= SoilDepth)",
                    "                        SoilPAW = SoilPAW + physical.DULmm[z] - physical.LL15mm[z];",
                    "                }",
                    "",
                    "                if (SoilPAW <= CritPAWForShallow)",
                    "                {",
                    "                    IrrigDeficit = PercPAWIrrigDeficitShallow / (double)100 * SoilPAW;",
                    "                    IrrigReturn = IrrigReturnShallow;",
                    "                    IrrigAmt = IrrigAmtShallow;",
                    "                    IrrigEff = IrrigEffShallow;",
                    "                    summary.WriteMessage(this, \"Soil is considered to be shallow \" + CritPAWForShallow + \" \" + SoilPAW, MessageType.Information);",
                    "                }",
                    "                else",
                    "                {",
                    "                    IrrigDeficit = IrrigDeficitDeep;",
                    "                    IrrigReturn = IrrigReturnDeep;",
                    "                    IrrigAmt = IrrigAmtDeep;",
                    "                    IrrigEff = IrrigEffDeep;",
                    "                    summary.WriteMessage(this, \"Soil is considered to be deep\", MessageType.Information);",
                    "                }",
                    "",
                    "                summary.WriteMessage(this, $\"Irrigation critical deficit (mm): {IrrigDeficit}\", MessageType.Information);",
                    "                summary.WriteMessage(this, $\"        Irrigation return (days): {IrrigReturn}\", MessageType.Information);",
                    "                summary.WriteMessage(this, $\"   Irrigation pumped amount (mm): {IrrigAmt}\", MessageType.Information);",
                    "                summary.WriteMessage(this, $\"       Irrigation efficiency (%): {IrrigEff}\", MessageType.Information);",
                    "            }",
                    "        }",
                    "        ",
                    "        ",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "            if (AllowIrrigation)",
                    "            {",
                    "",
                    "                Rain_3[2] = Rain_3[1];",
                    "                Rain_3[1] = Rain_3[0];",
                    "                Rain_3[0] = weather.Rain;",
                    "                Rain3 = Rain_3[0] + Rain_3[1] + Rain_3[2];",
                    "                if (Rain3 >= CritRainToPause)",
                    "                    Days2Pause = DaysToPauseOnCritRain;",
                    "                else",
                    "                    Days2Pause = Days2Pause - 1;",
                    "",
                    "                TodayDeficit = 0.0;",
                    "                SoilPAW = 0.0;",
                    "                double mySoilDepth = 0;",
                    "",
                    "                for (int z = 0; z <= physical.Thickness.Length - 1; z++)",
                    "                {",
                    "                    mySoilDepth = mySoilDepth + physical.Thickness[z];",
                    "                    if (mySoilDepth <= SoilDepth)",
                    "                    {",
                    "                        SoilPAW = SoilPAW + physical.DULmm[z] - physical.LL15mm[z];",
                    "                        TodayDeficit = TodayDeficit + physical.DULmm[z] - Math.Min(physical.DULmm[z], water.MM[z]);",
                    "                    }",
                    "                }",
                    "                TodayDeficit_nve = -1 * TodayDeficit;",
                    "    ",
                    "                if (DateUtilities.WithinDates(IrrigStart, clock.Today, IrrigEnd))",
                    "                {",
                    "                    if (SoilPAW <= CritPAWForShallow)",
                    "                    {",
                    "                        IrrigDeficit = PercPAWIrrigDeficitShallow / 100 * SoilPAW;",
                    "                        IrrigReturn = IrrigReturnShallow;",
                    "                        IrrigAmt = IrrigAmtShallow;",
                    "                        IrrigEff = IrrigEffShallow;",
                    "                    }",
                    "                    else",
                    "                    {",
                    "                        IrrigDeficit = IrrigDeficitDeep;",
                    "                        IrrigReturn = IrrigReturnDeep;",
                    "                        IrrigAmt = IrrigAmtDeep;",
                    "                        IrrigEff = IrrigEffDeep;",
                    "                    }",
                    "",
                    "                    if (Days2Pause < 0.5)",
                    "                    {",
                    "                        IrrigDay = IrrigDay + 1;",
                    "                        if (IrrigDay > IrrigReturn)",
                    "                            IrrigDay = 1;// and day = 1 is when the irrigation happens",
                    "    ",
                    "                        if (TodayDeficit >= IrrigDeficit)",
                    "                        {",
                    "                            if (IrrigDay == 1)",
                    "                                irrigation.Apply(amount: IrrigAmt / (IrrigEff / 100.0));",
                    "                        }",
                    "                    }",
                    "                }",
                    "            }",
                    "        }    ",
                    "        ",
                    "        ",
                    "        private double GetAverageAnnualRainfallFromFile(string fileName)",
                    "        {",
                    "            using StreamReader reader = new StreamReader(fileName);",
                    "            string line;",
                    "            while ((line = reader.ReadLine()) != null)",
                    "            {",
                    "                if (line.StartsWith(\"!     Annual\"))",
                    "                {",
                    "                    string[] tokens = line.Split(' ', StringSplitOptions.RemoveEmptyEntries);",
                    "                    if (tokens.Length == 10)",
                    "                        return Convert.ToDouble(tokens[4]);",
                    "                }            ",
                    "            }",
                    "            ",
                    "            throw new Exception($\"Cannot find average annual rainfall amount in file: {fileName}\");",
                    "        }        ",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "AllowIrrigation",
                      "Value": "True"
                    },
                    {
                      "Key": "CriticalAnnualAverageRainfall",
                      "Value": "0"
                    },
                    {
                      "Key": "IrrigStart",
                      "Value": "1-sep"
                    },
                    {
                      "Key": "IrrigEnd",
                      "Value": "30-apr"
                    },
                    {
                      "Key": "SoilDepth",
                      "Value": "500"
                    },
                    {
                      "Key": "CritPAWForShallow",
                      "Value": "60"
                    },
                    {
                      "Key": "CritRainToPause",
                      "Value": "30"
                    },
                    {
                      "Key": "DaysToPauseOnCritRain",
                      "Value": "3"
                    },
                    {
                      "Key": "IrrigReturnShallow",
                      "Value": "2"
                    },
                    {
                      "Key": "IrrigAmtShallow",
                      "Value": "10"
                    },
                    {
                      "Key": "PercPAWIrrigDeficitShallow",
                      "Value": "30"
                    },
                    {
                      "Key": "IrrigEffShallow",
                      "Value": "100"
                    },
                    {
                      "Key": "IrrigReturnDeep",
                      "Value": "4"
                    },
                    {
                      "Key": "IrrigAmtDeep",
                      "Value": "20"
                    },
                    {
                      "Key": "IrrigDeficitDeep",
                      "Value": "25"
                    },
                    {
                      "Key": "IrrigEffDeep",
                      "Value": "100"
                    }
                  ],
                  "Name": "ContingentCentrePivot",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using APSIM.Core;",
                    "using System.Linq;",
                    "using System.Collections.Generic;",
                    "using Models.Surface;",
                    "using Models.Soils.Nutrients;",
                    "using Models.WaterModel;",
                    "using Models.Soils;",
                    "using Models.PMF;",
                    "using Models.Core;",
                    "using Models.Interfaces;",
                    "using APSIM.Shared.Utilities;",
                    "using System.Xml.Serialization;",
                    "using System;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class TreatmentScript : Model, IStructureDependency",
                    "    {",
                    "        [Link] private Clock clock;",
                    "        [Link] private IPhysical physical;",
                    "        [Link] private WaterBalance waterBalance;",
                    "        [Link] private ISummary summary;",
                    "        [Link] private Fertiliser fertiliser;",
                    "        [Link] private Irrigation irrigation;",
                    "        [Link] private Nutrient nutrient;",
                    "        [Link] private DateChangerScript dateChangerScript;",
                    "        //[Link] private Report report;",
                    "        [Link] private SurfaceOrganicMatter surfaceOrganicMatter;",
                    "        [Link] private IWeather weather;",
                    "        [field:NonSerialized]",
                    "        public IStructure Structure { private get; set; }",
                    "        //> Links to other Apsim models",
                    "//        [Link] private Nitrification nitrification;",
                    "",
                    "        ",
                    "        [Separator(\"Initialises the experiment and controls the treatment applications of urine, dung and fertiliser\")]",
                    "        [Separator(\"     Control - no N, no water\")]",
                    "        [Separator(\"     Urine - 600 kg urea-N distributed to 175 mm, 10 mm water\")]",
                    "        [Separator(\"     Dung - 1100 kg N and 15,000 kg C /ha as ruminant dung to SurfaceOrganicMatter, 25 mm water\")]",
                    "        [Separator(\"     Fertiliser - 50 kg/ha urea-N, no water\")]",
                    "        [Separator(\"     \")]",
                    "        [Separator(\"     Updated the dung incorporation\")]",
                    "",
                    "        [Description(\"Treatment type\")]",
                    "        public TreatmentTypes TreatmentType {get; set;}",
                    "",
                    "        //[XmlIgnore] public double Slope {get; set;}   // percent",
                    "",
                    "        [XmlIgnore] public DateTime myApplicationDate {get; set;}",
                    "        ",
                    "        [XmlIgnore] public double NApplied { get; set; }",
                    "        [XmlIgnore] public double UrineDepth { get; set; }",
                    "        [XmlIgnore] public double[] weights { get; set; }",
                    "",
                    "        [XmlIgnore] public double[] weights200mm { get; set; }",
                    "        [XmlIgnore] public double[] weights150mm { get; set; }",
                    "        [XmlIgnore] public double[] weights175mm { get; set; }",
                    "        ",
                    "        [XmlIgnore] public double relativeWaterContent { get; set; }",
                    "        [XmlIgnore] public double VolatilisationRate { get; set; }",
                    "        [XmlIgnore] public double VolatilisationLoss { get; set; }",
                    "        [XmlIgnore] public double VolatilisationDiscount { get; set; }",
                    "        ",
                    "        ",
                    "",
                    "        [Units(\"mm\")]",
                    "        public double Rain3 {get; set; }",
                    "        ",
                    "        [Units(\"mm\")]",
                    "        public double[] Rain_3 {get; set; } = new double[3];",
                    "        ",
                    "",
                    "",
                    "/*      Volatilization was essentially complete after 100-200 hours. Mean volatilization losses from urine treated plots were ",
                    "            22.2% of the applied nitrogen (N) in summer, ",
                    "            24.6% in autumn and ",
                    "            12.2% in winter. Corresponding losses from the ",
                    "            urea treated plots were 17.9%, 28.9% and 8.5%.",
                    "            https://hdl.handle.net/10182/1620 Sherlock thesis   ",
                    "            ",
                    "            Ammonia volatilisation losses from fertiliser are typically <15% of the N applied, Gray https://doi.org/10.1080/00288233.2023.2198719",
                    "            ",
                    "                */",
                    "",
                    "        ",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void OnStartOfSimulation(object sender, EventArgs e)",
                    "        {",
                    "            NApplied = 0.0;",
                    "            UrineDepth = 175.0;",
                    "            myApplicationDate = dateChangerScript.ApplicationDate;",
                    "",
                    "            Rain3 = 0.0;",
                    "            Rain_3[0] = 0.0; Rain_3[1] = 0.0; Rain_3[2] = 0.0;",
                    "            ",
                    "        }",
                    "        ",
                    "        [EventSubscribe(\"StartOfDay\")]",
                    "        private void OnStartOfDay(object sender, EventArgs e)",
                    "        {",
                    "        }",
                    "        ",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "",
                    "            Rain_3[2] = Rain_3[1];",
                    "            Rain_3[1] = Rain_3[0];",
                    "            Rain_3[0] = weather.Rain + irrigation.IrrigationApplied;   // there will not be any irrigation from the urine at this point of the day",
                    "            Rain3 = Rain_3[0] + Rain_3[1] + Rain_3[2];",
                    "            ",
                    "            VolatilisationLoss = 0.0;",
                    "            VolatilisationDiscount = 1.0 - Math.Min(1.0, Rain3/10.0);",
                    "",
                    "            if (clock.Today == myApplicationDate)",
                    "            {",
                    "                // find the volatilisation rate",
                    "                   if ((clock.Today.Month <= 4) || (clock.Today.Month >= 9))",
                    "                       VolatilisationRate = 0.15;",
                    "                   else ",
                    "                       VolatilisationRate = 0.05;",
                    "",
                    "                if (TreatmentType.ToString() == \"Control\")",
                    "                    {",
                    "                        NApplied = 0.0;",
                    "                        VolatilisationRate = 0.0;",
                    "                        VolatilisationLoss = 0.0;",
                    "                    }",
                    "                else if (TreatmentType.ToString() == \"Urine\")",
                    "                {",
                    "",
                    "                    VolatilisationLoss = VolatilisationRate * 600.0 * VolatilisationDiscount;",
                    "                    weights = GetLayerWeightsForDistribution(UrineDepth);",
                    "                    ",
                    "                    double cumulativeDepth = 0.0;",
                    "                    for (int i = 0; i < physical.Thickness.Length; i++)",
                    "                    {",
                    "                        cumulativeDepth += physical.Thickness[i];",
                    "                        //if (weights200mm[i] > 0.0)",
                    "                        //{",
                    "                            fertiliser.Apply((600.0 - VolatilisationLoss) * weights[i], \"UreaN\", cumulativeDepth - (physical.Thickness[i] / 2.0) );",
                    "                            irrigation.Apply(amount: 10.0 * weights[i], depth: (cumulativeDepth - (physical.Thickness[i] / 2.0)), efficiency: 1.0, willRunoff: false, nh4: 0.0);",
                    "                        //}  ",
                    "                        NApplied += 600.0 * weights[i];",
                    "                    }",
                    "                    ",
                    "                }",
                    "                else if (TreatmentType.ToString() == \"Dung\")",
                    "                {",
                    "                    VolatilisationRate = 0.0;",
                    "                    VolatilisationLoss = 0.0;",
                    "",
                    "                    surfaceOrganicMatter.Add(mass: 15000.0, N: 1100.0, P: 0.0, type: \"RuminantDung_PastureFed\", name: \"Manure\", fractionStanding: 0.0, no3: 0.0, nh4: 0.0);",
                    "                    irrigation.Apply(amount: 25.0, depth: 0.0, efficiency: 1.0, willRunoff: false, nh4: 0.0);",
                    "                    NApplied = 1100;",
                    "                    ",
                    "                    Simulation sim =   Structure.FindParent<Simulation>(recurse: true) as Simulation;",
                    "                    ResidueTypes rts =   Structure.FindChild<ResidueTypes>(recurse: true, relativeTo: (INodeModel)sim) as ResidueTypes;",
                    "                    foreach(ResidueType rt in rts.ResidueType) ",
                    "                        {rt.pot_decomp_rate = 0.05;}",
                    "                    ",
                    "                }",
                    "                else if (TreatmentType.ToString() == \"Fertiliser\")",
                    "                {",
                    "                     VolatilisationLoss = VolatilisationRate * 50.0;",
                    "",
                    "                   // no water after the fertiliser",
                    "                    fertiliser.Apply((50.0 - VolatilisationLoss), \"UreaN\", 0.0);",
                    "                    summary.WriteMessage(this, \"N addition of 50 kg N /ha to the soil surface\", MessageType.Information); ",
                    "                    NApplied = 50.0;",
                    "                }",
                    "                else",
                    "                    throw new Exception(TreatmentType + \" is not a valid treatment type\");",
                    "            }",
                    "            ",
                    "            if (TreatmentType.ToString() == \"Dung\")",
                    "            {",
                    "                if ((clock.Today >= myApplicationDate) && ((surfaceOrganicMatter.LyingWt + surfaceOrganicMatter.StandingWt) > 25.0))",
                    "                {",
                    "                    double criticalWaterContent = (physical.DUL[1] - (physical.DUL[1] - physical.LL15[1])/3.0);",
                    "                    if (Rain3 > 10.0)",
                    "                        relativeWaterContent = 1.0;",
                    "                    else if (waterBalance.SW[1] < criticalWaterContent)  ",
                    "                        relativeWaterContent = 0.0;",
                    "                    else if (waterBalance.SW[1] < physical.DUL[1])",
                    "                        relativeWaterContent = 1.0 - (waterBalance.SW[1] - criticalWaterContent) / (physical.DUL[1] - criticalWaterContent);",
                    "                    else ",
                    "                        relativeWaterContent = 1.0;",
                    "                        ",
                    "                    double fraction = 0.1; ",
                    "                    surfaceOrganicMatter.Incorporate(fraction: fraction * relativeWaterContent, depth: 100.0, doOutput: false);",
                    "                         ",
                    "                    ",
                    "                }",
                    "",
                    "            }",
                    "    ",
                    "",
                    "        }",
                    "        ",
                    "        ",
                    "        private double[] GetLayerWeightsForDistribution(double thisDepth)",
                    "        {",
                    "            double[] weights = new double[physical.Thickness.Length];",
                    "            double cumDepth = 0;",
                    "            double initialSum = 0.0;",
                    "            for (int i = 0; i < physical.Thickness.Length; i++)",
                    "            {",
                    "                cumDepth += physical.Thickness[i];    // the end depth of the current layer",
                    "                if (cumDepth < thisDepth)             // all the layer is within the deposition depth",
                    "                    weights[i] = 1.0;    ",
                    "                else if (cumDepth - physical.Thickness[i] <= thisDepth)",
                    "                    weights[i] = (thisDepth - (cumDepth - physical.Thickness[i])) / physical.Thickness[i];    // part of this layer will contribute",
                    "                else",
                    "                    weights[i] = 0;                 // non of this layer will contribute",
                    "                ",
                    "                initialSum += weights[i];",
                    "            }",
                    "            ",
                    "            for (int i = 0; i < physical.Thickness.Length; i++)",
                    "            {",
                    "                weights[i] /= initialSum;",
                    "            }",
                    "            ",
                    "            return weights;",
                    "        }",
                    "",
                    "",
                    "        /// <summary>Treatment types</summary>",
                    "        public enum TreatmentTypes",
                    "        {",
                    "            /// <summary>Control</summary>",
                    "            Control,",
                    "            ",
                    "            /// <summary>Urine</summary>",
                    "            Urine,",
                    "            ",
                    "            /// <summary>Dung</summary>",
                    "            Dung,",
                    "            ",
                    "            /// <summary>Fertiliser</summary>",
                    "            Fertiliser",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "TreatmentType",
                      "Value": "Urine"
                    }
                  ],
                  "Name": "Treatment",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.AgPasture.SimpleGrazing, Models",
                  "GrazingRotationType": 1,
                  "SimpleGrazingFrequencyString": null,
                  "SimpleMinGrazable": 0.0,
                  "SimpleGrazingResidual": 0.0,
                  "PreGrazeDMArray": [
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0,
                    2500.0
                  ],
                  "PostGrazeDMArray": [
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0,
                    1250.0
                  ],
                  "FlexibleExpressionForTimingOfGrazing": null,
                  "FlexibleGrazePostDM": 0.0,
                  "MaximumRotationLengthArray": [
                    60.0,
                    60.0,
                    60.0,
                    60.0,
                    60.0,
                    60.0,
                    60.0,
                    60.0,
                    60.0,
                    60.0,
                    60.0,
                    60.0
                  ],
                  "MinimumRotationLengthArray": [
                    15.0,
                    15.0,
                    15.0,
                    15.0,
                    15.0,
                    15.0,
                    15.0,
                    15.0,
                    15.0,
                    15.0,
                    15.0,
                    15.0
                  ],
                  "NoGrazingStartString": null,
                  "NoGrazingEndString": null,
                  "IsCutAndCarry": false,
                  "FractionClippingsReturned": 0.0,
                  "FractionIntakeNToAnimal": [
                    0.6
                  ],
                  "DungNConc": 2.6,
                  "FractionOfDungUrineOffPaddock": [
                    0.6
                  ],
                  "DepthUrineIsAdded": 150.0,
                  "ShowAdvancedExcretaOptions": false,
                  "SendDungElsewhere": 1.0,
                  "SendUrineElsewhere": 1.0,
                  "UsePatching": false,
                  "PseudoPatches": true,
                  "ZoneCount": 25,
                  "UrineReturnPattern": 2,
                  "PseudoRandomSeed": 666,
                  "FractionPopulationDecline": 0.0,
                  "TramplingOn": false,
                  "MaximumPropLitterMovedToSoil": 0.1,
                  "PastureConsumedAtMaximumRateOfLitterRemoval": 1200.0,
                  "Name": "SimpleGrazing",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "// Gets an output at a particular depth for reporting",
                    "using System;",
                    "using System.Xml.Serialization;",
                    "using APSIM.Shared.Utilities;",
                    "using Models.Interfaces;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using Models.Soils.Nutrients;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    [System.Xml.Serialization.XmlInclude(typeof(Model))]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] private Clock clock;",
                    "        [Link] private IPhysical physical;",
                    "        [Link] private ISoilWater soilWater;",
                    "        [Link] private Nutrient nutrient;",
                    "        [Link(ByName = true)] private ISolute urea;",
                    "        [Link(ByName = true)] private ISolute nH4;",
                    "        [Link(ByName = true)] private ISolute nO3;",
                    "        [Link] private ISummary summary;",
                    "",
                    "        [Separator(\"This just gets leaching at the specified depth for reporting\")]",
                    "",
                    "        [Description(\"Depth for reporting (mm)\")]",
                    "        public double TargetDepth { get; set; }",
                    "",
                    "        [XmlIgnore] public double LeachingForOutput { get; set; }",
                    "        [XmlIgnore] public double DrainageForOutput { get; set; }",
                    "        [XmlIgnore] public double DenitrificationForOutput { get; set; }",
                    "        [XmlIgnore] public double N2OForOutput { get; set; }",
                    "        [XmlIgnore] public int Layer { get; set; }",
                    "",
                    "",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void OnStartOfSimulation(object sender, EventArgs e)",
                    "        {",
                    "            Layer = 0;",
                    "            for (int i = 0; i < physical.Thickness.Length; i++)",
                    "            {",
                    "                if (Layer < 1 && physical.ThicknessCumulative[i] >= TargetDepth)  // this will only trigger the first time the cumulative depth is greater than the target depth",
                    "                    Layer = i;   ",
                    "            }",
                    "        }",
                    "",
                    "        [EventSubscribe(\"DoReportCalculations\")]",
                    "        private void OnDoReportCalculations(object sender, EventArgs e)",
                    "        {",
                    "            LeachingForOutput = urea.Flow[Layer] + nH4.Flow[Layer] + nO3.Flow[Layer];",
                    "            DrainageForOutput = soilWater.Flow[Layer] + soilWater.Flux[Layer];",
                    "            ",
                    "            DenitrificationForOutput = 0.0;",
                    "            N2OForOutput = 0.0;",
                    "            for (int i = 0; i <= Layer; i++)",
                    "            {",
                    "                DenitrificationForOutput += nutrient.DenitrifiedN[i];",
                    "                if (physical.ThicknessCumulative[i] <= 373.0)",
                    "                    N2OForOutput += nutrient.N2Oatm[i];",
                    "            }",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "TargetDepth",
                      "Value": "1000"
                    }
                  ],
                  "Name": "Outputs",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": false,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using System;",
                    "using System.Xml.Serialization;",
                    "using APSIM.Shared.Utilities;",
                    "using Models.Interfaces;",
                    "using Models.Core;",
                    "using Models.PMF;",
                    "using Models.Soils;",
                    "using Models.Soils.Nutrients;",
                    "using Models.Soils.SoilTemp;",
                    "using System.Diagnostics;",
                    "using Models.WaterModel;",
                    "using System.Linq;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    [System.Xml.Serialization.XmlInclude(typeof(Model))]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] private Clock clock;",
                    "        [Link] private IPhysical physical;",
                    "        [Link] private ISoilWater soilWater;",
                    "        [Link] private Nutrient nutrient;",
                    "        [Link] private SoilTemperature temperature; ",
                    "        [Link(ByName = true)] private ISolute urea;",
                    "        [Link(ByName = true)] private ISolute nH4;",
                    "        [Link(ByName = true)] private ISolute nO3;",
                    "        [Link] private ISummary summary;",
                    "        //[Link(ByName = true)] private Treatment treatmentScript;",
                    "        [Link] private TreatmentScript treatmentScript;",
                    "        [Link] private DateChangerScript dateChangerScript;",
                    "        [Link] private Report report;",
                    "",
                    "",
                    "        [XmlIgnore] public double N2O300mm { get; set; }",
                    "        [XmlIgnore] public double cumN2O300mm { get; set; }",
                    "        [XmlIgnore] public double SoilMinN75mm { get; set; }",
                    "        [XmlIgnore] public double SoilTemperature100mm { get; set; }",
                    "        [XmlIgnore] public double WFPS75mm { get; set; }",
                    "        [XmlIgnore] public double PoreSpace75mm { get; set; }",
                    "        [XmlIgnore] public double SoilWater75mm { get; set; }",
                    "        [XmlIgnore] public double SoilWaterVol75mm { get; set; }",
                    "        [XmlIgnore] public double Air75mm { get; set; }",
                    "        [XmlIgnore] public double AirVol75mm { get; set; }",
                    "        [XmlIgnore] public double RoughEF { get; set; }",
                    "",
                    "        [XmlIgnore] public int Layer { get; set; }",
                    "        [XmlIgnore] public double[] weightsPickLayer100mm { get; set; }",
                    "        [XmlIgnore] public double[] weightsPickLayer75mm { get; set; }",
                    "        [XmlIgnore] public double[] weights50mm { get; set; }",
                    "        [XmlIgnore] public double[] weights75mm { get; set; }",
                    "        [XmlIgnore] public double[] weights300mm { get; set; }",
                    "",
                    "",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void OnStartOfSimulation(object sender, EventArgs e)",
                    "        {",
                    "           //Debugger.Break();",
                    "",
                    "           weights300mm = GetLayerWeightsForOutputting(300.0);",
                    "           weights75mm = GetLayerWeightsForOutputting(75.0);",
                    "           weights50mm = GetLayerWeightsForOutputting(50.0);",
                    "           weightsPickLayer100mm = PickLayerForOutputting(100.0);",
                    "           weightsPickLayer75mm = PickLayerForOutputting(75.0);",
                    "           cumN2O300mm = 0.0;",
                    "           ",
                    "        }",
                    "",
                    "        [EventSubscribe(\"DoReportCalculations\")]",
                    "        private void OnDoReportCalculations(object sender, EventArgs e)",
                    "        {",
                    "            N2O300mm = 0.0;",
                    "            SoilMinN75mm = 0.0;",
                    "            AirVol75mm = 0.0;",
                    "            SoilTemperature100mm = 0.0;",
                    "            SoilWaterVol75mm = 0.0;",
                    "            ",
                    "            double bD75mm = 0.0;",
                    "            double poreSpace75mm = 0.0;",
                    "            double soilWater75mm = 0.0;",
                    "            ",
                    "            for (int i = 0; i < physical.Thickness.Length; i++)",
                    "            {",
                    "                N2O300mm += nutrient.N2Oatm[i] * weights300mm[i];",
                    "                SoilMinN75mm += (urea.kgha[i] + nH4.kgha[i] + nO3.kgha[i]) * weights75mm[i];",
                    "                SoilTemperature100mm += temperature.AverageSoilTemperature[i] * weightsPickLayer100mm[i];",
                    "                SoilWaterVol75mm += soilWater.SW[i] * weightsPickLayer75mm[i];",
                    "                AirVol75mm += ((1 - (physical.BD[i] / 2.65)) - soilWater.SW[i]) * weightsPickLayer75mm[i];",
                    "                ",
                    "                bD75mm += physical.BD[i] * weightsPickLayer75mm[i]; ",
                    "                poreSpace75mm += (1 - (physical.BD[i] / 2.65)) * weights75mm[i];",
                    "                soilWater75mm += soilWater.SWmm[i] * weights75mm[i];",
                    "            }",
                    "            ",
                    "\t\t\tif (clock.Today >= dateChangerScript.ApplicationDateMinus1)",
                    "                cumN2O300mm += N2O300mm;",
                    "",
                    "            if (treatmentScript.NApplied >= 0.001)",
                    "                RoughEF = cumN2O300mm / treatmentScript.NApplied * 100.0; ",
                    "            else",
                    "                RoughEF = 0.0;",
                    "            ",
                    "            //PoreSpace75mm = 1 - BD75mm / 2.65;",
                    "            WFPS75mm = soilWater75mm/(poreSpace75mm * 75.0);",
                    "        }",
                    "",
                    "\t\t[EventSubscribe(\"EndOfDay\")]",
                    "\t\tprivate void OnEndOfDay(object sender, EventArgs e)",
                    "\t\t{",
                    "\t\t\t/*if (clock.Today == dateChangerScript.ApplicationDateMinus8)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDateMinus7)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDateMinus1)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus1)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus3)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus7)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus30)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus60)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus90)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus120)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus150)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus180)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus270)",
                    "\t\t\t    report.DoOutput();",
                    "\t\t\telse if (clock.Today == dateChangerScript.ApplicationDatePlus360)",
                    "\t\t\t    report.DoOutput(); */",
                    "\t\t}",
                    "",
                    "",
                    "        private double[] GetLayerWeightsForOutputting(double thisDepth)",
                    "        {",
                    "            double[] weights = new double[physical.Thickness.Length];",
                    "            double cumDepth = 0;",
                    "            for (int i = 0; i < physical.Thickness.Length; i++)",
                    "            {",
                    "                cumDepth += physical.Thickness[i];    // the end depth of the current layer",
                    "                if (cumDepth < thisDepth)             // all the layer is within the deposition depth",
                    "                    weights[i] = 1.0;    ",
                    "                else if (cumDepth - physical.Thickness[i] <= thisDepth)",
                    "                    weights[i] = (thisDepth - (cumDepth - physical.Thickness[i])) / physical.Thickness[i];    // part of this layer will contribute",
                    "                else",
                    "                    weights[i] = 0;                 // non of this layer will contribute",
                    "            }",
                    "            return weights;",
                    "        }",
                    "",
                    "        private double[] PickLayerForOutputting(double thisDepth)",
                    "        {",
                    "            double[] weights = new double[physical.Thickness.Length];",
                    "            double cumDepth = 0;",
                    "            for (int i = 0; i < physical.Thickness.Length; i++)",
                    "            {",
                    "                cumDepth += physical.Thickness[i];    // the end depth of the current layer",
                    "                if (thisDepth >= (cumDepth - physical.Thickness[i]) && (thisDepth <= cumDepth))",
                    "                    weights[i] = 1.0; ",
                    "                else",
                    "                    weights[i] = 0.0; ",
                    "            }",
                    "            return weights;",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [],
                  "Name": "OutputsEssPre",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": false,
