          "$type": "Models.Core.Simulation, Models",
          "Descriptors": null,
          "Name": "Base",
          "ResourceName": null,
          "Children": [
            {
              "$type": "Models.Manager, Models",
              "CodeArray": [
                "using System;",
                "using System.Xml.Serialization;",
                "using APSIM.Shared.Utilities;",
                "using Models.Interfaces;",
                "using Models.Core;",
                "using Models.PMF;",
                "using Models.Soils;",
                "using Models.WaterModel;",
                "",
                "namespace Models",
                "{",
                "\t[Serializable]",
                "\tpublic class DateChangerScript : Model",
                "\t{",
                "\t\t//> Links to other Apsim models",
                "\t\t[Link] private Clock clock;",
                "        [Link] private ISummary summary;",
                "\t",
                "\t\t[Separator(\"Change the start and end date from the factor levels\")]",
                "",
                "",
                "\t\t[Description(\"Year of interest\")]",
                "\t\tpublic int Year {get; set;}",
                "",
                "\t\t[Description(\"Month of interest\")]",
                "\t\tpublic int Month {get; set;}",
                "",
                "\t\t[Description(\"Day of interest\")]",
                "\t\tpublic int Day {get; set;}",
                "",
                "\t\t[XmlIgnore] public string DateAsString {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDate {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDateMinus1 {get; set;}",
                "\t\t//[XmlIgnore] public DateTime ApplicationDatePlus120 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus140 {get; set;}",
                "\t\t[XmlIgnore] public int DaysSinceApplication {get; set;}",
                "\t\t",
                "",
                "\t\t[XmlIgnore] public DateTime ApplicationDateMinus8 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDateMinus7 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus1 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus3 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus7 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus30 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus60 {get; set;}",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus90 {get; set;}  // 3 months",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus120 {get; set;}  // 4 months",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus150 {get; set;}  // 5 months",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus180 {get; set;}   // 6 mpnths",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus270 {get; set;}   // 9 mpnths",
                "\t\t[XmlIgnore] public DateTime ApplicationDatePlus360 {get; set;}   // 12 mpnths",
                "",
                "",
                "",
                "\t\t[EventSubscribe(\"Commencing\")]",
                "\t\tprivate void OnComencing(object sender, EventArgs e)",
                "\t\t{",
                "",
                "            DateAsString = Day + \"-\" + Month + \"-\" + Year;",
                "            ApplicationDate = new DateTime(Year, Month, Day);",
                "            ",
                "            clock.StartDate = ApplicationDate.AddMonths(-3);",
                "            clock.EndDate = ApplicationDate.AddYears(2).AddDays(-1);",
                "            ",
                "            //ApplicationDatePlus140 = ApplicationDate.AddDays(140);",
                "",
                "            ApplicationDateMinus8 = ApplicationDate.AddDays(-8);   // just for zeroing",
                "            ApplicationDateMinus7 = ApplicationDate.AddDays(-7);",
                "            ApplicationDateMinus1 = ApplicationDate.AddDays(-1);",
                "            ApplicationDatePlus1 = ApplicationDate.AddDays(0);",
                "            ApplicationDatePlus3 = ApplicationDate.AddDays(2);",
                "            ApplicationDatePlus7 = ApplicationDate.AddDays(6);",
                "            ApplicationDatePlus30 = ApplicationDate.AddDays(29);",
                "            ApplicationDatePlus60 = ApplicationDate.AddDays(59);",
                "            ApplicationDatePlus90 = ApplicationDate.AddDays(89);",
                "            ApplicationDatePlus120 = ApplicationDate.AddDays(119);",
                "            ApplicationDatePlus150 = ApplicationDate.AddDays(149);",
                "            ApplicationDatePlus180 = ApplicationDate.AddDays(179);",
                "            ApplicationDatePlus270 = ApplicationDate.AddDays(269);",
                "            ApplicationDatePlus360 = ApplicationDate.AddDays(359);",
                "            ",
                "\t\t}",
                "\t\t",
                "\t\t[EventSubscribe(\"StartOfSimulation\")]",
                "\t\tprivate void OnStartOfSimulation(object sender, EventArgs e)",
                "\t\t{",
                "            summary.WriteMessage(this, \"The simulation start date will be \" + clock.StartDate, MessageType.Information);",
                "            summary.WriteMessage(this, \"The application date will be \" + ApplicationDate, MessageType.Information);",
                "            summary.WriteMessage(this, \"The simulation end date will be \" + clock.EndDate, MessageType.Information);",
                "            ",
                "\t\t}",
                "\t\t",
                "\t\t[EventSubscribe(\"StartOfDay\")]",
                "\t\tprivate void OnStartOfDay(object sender, EventArgs e)",
                "\t\t{",
                "\t\t}",
                "\t\t",
                "\t\t[EventSubscribe(\"DoManagement\")]",
                "\t\tprivate void OnDoManagement(object sender, EventArgs e)",
                "\t\t{",
                "\t\t    DaysSinceApplication = (clock.Today - ApplicationDateMinus1).Days;",
                "\t\t}",
                "\t\t",
                "\t}",
                "}"
              ],
              "Parameters": [
                {
                  "Key": "Year",
                  "Value": "1900"
                },
                {
                  "Key": "Month",
                  "Value": "1"
                },
                {
                  "Key": "Day",
                  "Value": "15"
                }
              ],
              "Name": "DateChanger",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            },
