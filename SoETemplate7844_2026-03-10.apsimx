                {
                  "$type": "Models.Report, Models",
                  "VariableNames": [
                    "[Clock].Today as Date",
                    "[Weather].FileName as Agent",
                    "[Soil].LocalName as Soil",
                    "[Treatment].TreatmentScript.myApplicationDate as DepositionDate",
                    "",
                    "",
                    "//PastureHarvested",
                    "Sum of ([AgPRyegrass].HarvestedWt + [AgPWhiteClover].HarvestedWt) from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as HarvestedWt",
                    "",
                    "// water ins and outs",
                    "Sum of [Weather].Rain from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Rainfall",
                    "Sum of [Irrigation].IrrigationApplied from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Irrigation",
                    "Sum of (sum([AgpRyegrass].WaterUptake[:]) + sum([AgpWhiteClover].WaterUptake[:]) from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Transpiration",
                    "Sum of [SoilWater].Es from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Evaporation",
                    "Sum of [ISoilWater].Runoff from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Runoff",
                    "Sum of ([SoilWater].Flow[1000mm] + [SoilWater].Flux[1000mm] from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Drainage",
                    "Rainfall + Irrigation - Transpiration - Evaporation - Runoff - Drainage as WaterBalance",
                    "",
                    "",
                    "// N ins and outs",
                    "[Treatment].TreatmentScript.NApplied as UrineN",
                    "Sum of [AgPWhiteClover].FixedN from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as FixedN",
                    "Sum of ([AgPRyegrass].HarvestedN + [AgPWhiteClover].HarvestedN) from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as HarvestedN",
                    "Sum of sum([Nutrient].DenitrifiedN[:]) from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Denitrification",
                    "Sum of [Nutrient].N2Oatm[0mm:300mm] from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as N2O",
                    "Sum of [Treatment].TreatmentScript.VolatilisationLoss from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Volatilisation",
                    "Sum of ([Urea].Flow[1000mm] + [NH4].Flow[1000mm] + [NO3].Flow[1000mm]) from [DateChanger].DateChangerScript.ApplicationDate to [Clock].Today as Leached"
                  ],
                  "EventNames": [
                    "",
                    "[Clock].EndOfSimulation"
                  ],
